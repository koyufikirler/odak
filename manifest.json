{
  "manifest_version": 3,
  "name": "Distraction Hider",
  "version": "1.0.0",
  "description": "Hide distracting elements on any webpage with a stunning particle dissolution effect. Click to pick, watch it dissolve.",
  "browser_specific_settings": {
    "gecko": {
      "id": "distraction-hider@extension",
      "strict_min_version": "121.0"
    }
  },
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Distraction Hider"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
